<Window x:Class="ThLaunchSite.Dialogs.AddUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThLaunchSite.Dialogs"
        mc:Ignorable="d"
        Title="ユーザーの追加" Height="144" Width="250" ResizeMode="NoResize" ShowInTaskbar="False" WindowStartupLocation="CenterOwner">
    <Grid>
        <Label Content="ユーザー名:" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="UserNameBox" Margin="10,36,10,0" TextWrapping="NoWrap" Text="" VerticalAlignment="Top"/>
        <Button x:Name="AddUserButton" IsDefault="True" Content="追加(_A)" HorizontalAlignment="Right" Margin="0,0,10,10" VerticalAlignment="Bottom" Width="90" Height="24" Click="AddUserButton_Click"/>
    </Grid>
</Window>
