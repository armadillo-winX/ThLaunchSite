<Window x:Class="ThLaunchSite.ManageEnternalToolsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThLaunchSite"
        mc:Ignorable="d"
        Title="外部ツールの管理" Height="348" Width="398" ResizeMode="NoResize" ShowInTaskbar="False" WindowStartupLocation="CenterOwner">
    <Grid>
        <ListBox x:Name="ExternalToolsListBox" Margin="10,10,105,10"/>
        <Button x:Name="AddToolButton" Content="追加(_A)"
                            HorizontalAlignment="Right" Margin="0,10,10,0" VerticalAlignment="Top" 
                            Width="90" Height="24" Click="AddToolButtonClick"/>
        <Button x:Name="DeleteToolButton" Content="削除(_D)"
                            Margin="0,39,10,0" VerticalAlignment="Top" HorizontalAlignment="Right"
                            Width="90" Height="24" Click="DeleteButtonClick" />
        <Button x:Name="OKButton" IsDefault="True" Content="_OK" Width="90" Height="24" HorizontalAlignment="Right" 
                Margin="0,0,10,10" VerticalAlignment="Bottom" Click="OKButtonClick"/>
    </Grid>
</Window>
