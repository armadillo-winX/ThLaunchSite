<Window x:Class="ThLaunchSite.GameRunningTimeStaticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThLaunchSite"
        mc:Ignorable="d"
        Title="ゲーム累積実行時間統計" Height="210" Width="296" ResizeMode="NoResize" ShowInTaskbar="False" WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow">
    <Grid>
        <Label Content="あなたは累積でこれだけの時間東方をプレイしています" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top"/>
        <TextBlock x:Name="GameRunningTimeBlock" HorizontalAlignment="Center" Margin="0,56,0,0" 
                   TextWrapping="Wrap" Text="00:00" VerticalAlignment="Top" FontSize="24" FontWeight="Bold"/>
        <Button x:Name="CloseButton" Width="90" Content="閉じる(_C)" IsDefault="True" HorizontalAlignment="Center" Margin="0,0,0,10" Click="CloseButton_Click" Height="24" VerticalAlignment="Bottom"/>

    </Grid>
</Window>
