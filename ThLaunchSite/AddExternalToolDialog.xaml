<Window x:Class="ThLaunchSite.AddExternalToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThLaunchSite"
        mc:Ignorable="d"
        Title="外部ツールの追加" Height="306" Width="301"
        ResizeMode="NoResize" ShowInTaskbar="False" 
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Label Content="ツール名:" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="ToolNameBox" Margin="10,36,10,0" TextWrapping="NoWrap" Text="" VerticalAlignment="Top" MaxLines="1"/>
        <Label Content="パス:" HorizontalAlignment="Left" Margin="10,59,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="PathBox" Margin="10,85,57,0" TextWrapping="NoWrap" Text="" VerticalAlignment="Top" MaxLines="1"/>
        <Button x:Name="BrowseButton" Content="参照(_B)" Margin="0,85,10,0" VerticalAlignment="Top" HorizontalAlignment="Right" Width="42" Click="BrowseButtonClick"/>
        <Label Content="オプション:" HorizontalAlignment="Left" Margin="10,108,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="OptionBox" Margin="10,134,10,0" TextWrapping="NoWrap" Text="" VerticalAlignment="Top" MaxLines="1"/>
        <Button x:Name="AddButton" IsDefault="True" Content="追加(_A)" HorizontalAlignment="Right" Margin="0,0,10,10" Width="90" Height="24" VerticalAlignment="Bottom" Click="AddButtonClick"/>
        <CheckBox x:Name="AsAdminCheckBox" Content="管理者特権を付与する" HorizontalAlignment="Center" Margin="0,181,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
