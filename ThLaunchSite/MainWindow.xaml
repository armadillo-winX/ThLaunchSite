<Window x:Class="ThLaunchSite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThLaunchSite"
        mc:Ignorable="d"
        Title="MainWindow" Height="331" Width="469">
    <Grid>
        <Menu Height="18" VerticalAlignment="Top">
            <MenuItem Header="ゲーム(_G)">
                <MenuItem x:Name="SetGamePathMenuItem" Header="ゲームのパスを設定(_S)">
                    <MenuItem.Icon>
                        <Image Source="/Images/Settings_12x_16x.png"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="ユーザー(_U)">
                <MenuItem x:Name="AddUserMenuItem" Header="ユーザーの追加(_A)" Click="AddUserMenuItem_Click">
                    <MenuItem.Icon>
                        <Image Source="/Images/User_16x.png"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem x:Name="AboutMenuItem" Header="このツールについて(_A)" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

    </Grid>
</Window>
