<Window x:Class="ThLaunchSite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThLaunchSite"
        mc:Ignorable="d"
        Title="MainWindow" Height="400" Width="550" ResizeMode="CanResizeWithGrip" Closing="Window_Closing" KeyDown="Window_KeyDown">
    <Grid>
        <Menu Height="18" VerticalAlignment="Top">
            <MenuItem Header="ゲーム(_G)">
                <MenuItem x:Name="LaunchGameMenuItem" Header="ゲームを起動する(_L)" 
                          Click="LaunchGameMenuItem_Click">
                    <MenuItem.Icon>
                        <Image Source="/Images/Run_16x.png"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="LaunchWithVpatchMenuItem" Header="VsyncPatchを適用して起動する(_V)" 
                          Click="LaunchWithVpatchMenuItem_Click"/>
                <MenuItem x:Name="LaunchWithThpracMenuItem" Header="thpracを適用して起動する(_T)"
                          Click="LaunchWithThpracMenuItem_Click"/>
                <Separator />
                <MenuItem x:Name="LaunchCustomProgramMenuItem" Header="環境カスタムプログラムを起動する(_C)"
                          Click="LaunchCustomeMenuItem_Click"/>
                <Separator />
                <MenuItem x:Name="CatchGameProcessMenuItem" Header="実行中のゲームプロセスの捕捉"
                          Click="CatchGameProcessMenuItem_Click"/>
                <MenuItem x:Name="KillGameProcessMenuItem" Header="ゲームプロセスを強制終了(_K)"
                          Click="KillGameProcessMenuItem_Click">
                    <MenuItem.Icon>
                        <Image Source="/Images/Stop_16x.png"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="オプション(_O)">
                <MenuItem x:Name="AlwaysOnTopMenuItem"
                          IsCheckable="True" Header="常に最前面に表示(_A)" Click="AlwaysOnTopMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem x:Name="AboutMenuItem" Header="このツールについて(_A)" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>
        <ToolBar x:Name="MainToolBar" Height="28" Margin="0,18,0,0" VerticalAlignment="Top">
            <ComboBox x:Name="GameComboBox" Width="120" SelectionChanged="GameComboBox_SelectionChanged">
                <ComboBoxItem Uid="Th06" Content="東方紅魔郷"/>
                <ComboBoxItem Uid="Th07" Content="東方妖々夢"/>
                <ComboBoxItem Uid="Th08" Content="東方永夜抄"/>
                <ComboBoxItem Uid="Th09" Content="東方花映塚"/>
                <ComboBoxItem Uid="Th10" Content="東方風神録"/>
                <ComboBoxItem Uid="Th11" Content="東方地霊殿"/>
                <ComboBoxItem Uid="Th12" Content="東方星蓮船"/>
                <ComboBoxItem Uid="Th13" Content="東方神霊廟"/>
                <ComboBoxItem Uid="Th14" Content="東方輝針城"/>
                <ComboBoxItem Uid="Th15" Content="東方紺珠伝"/>
                <ComboBoxItem Uid="Th16" Content="東方天空璋"/>
                <ComboBoxItem Uid="Th17" Content="東方鬼形獣"/>
                <ComboBoxItem Uid="Th18" Content="東方虹龍洞"/>
            </ComboBox>
            <Button x:Name="LaunchGameButton" ContextMenuService.Placement="Bottom" Click="LaunchGameButton_Click">
                <Button.ContextMenu>
                    <ContextMenu x:Name="LaunchGameButtonMenu" Placement="Bottom">
                        <MenuItem Header="ゲームを起動する(_L)" 
                          Click="LaunchGameMenuItem_Click">
                            <MenuItem.Icon>
                                <Image Source="/Images/Run_16x.png"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="VsyncPatchを適用して起動する(_V)" 
                          Click="LaunchWithVpatchMenuItem_Click"/>
                        <MenuItem Header="thpracを適用して起動する(_T)"
                          Click="LaunchWithThpracMenuItem_Click"/>
                        <Separator />
                        <MenuItem Header="環境カスタムプログラムを起動する(_C)"
                          Click="LaunchCustomeMenuItem_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/Run_16x.png" HorizontalAlignment="Left"></Image>
                        <TextBlock Text="Launch"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </ToolBar>
        <Label Content="パス:" HorizontalAlignment="Left" Margin="10,51,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="GamePathBox" IsReadOnly="True" Margin="46,55,57,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top"/>
        <Button x:Name="GamePathBrowseButton" Content="参照(_B)"  HorizontalAlignment="Right" Margin="0,54,10,0" VerticalAlignment="Top" Click="GamePathBrowseButton_Click"/>
        <StatusBar Height="22" VerticalAlignment="Bottom">
            <StatusBarItem x:Name="AuthorityBlock" Content="Authority" DockPanel.Dock="Right" Margin="0,0,20,0"/>
            <StatusBarItem x:Name="AppStatusBlock"/>
        </StatusBar>
        <TabControl Margin="0,78,0,22">
            <TabItem Header="管制パネル">
                <Grid>
                    <ScrollViewer
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" CanContentScroll="True">
                        <Grid>
                            <TextBlock HorizontalAlignment="Left"
                                       Margin="10,10,0,0" TextWrapping="Wrap" Text="ウィンドウリサイザ" VerticalAlignment="Top"/>
                            <Label Content="リサイズ率:" HorizontalAlignment="Left" Margin="10,51,0,0" VerticalAlignment="Top"/>
                            <ComboBox x:Name="ResizeRateComboBox"
                                      HorizontalAlignment="Left" Margin="75,53,0,0" VerticalAlignment="Top" Width="120">
                                <ComboBoxItem Content="50%"/>
                                <ComboBoxItem Content="75%"/>
                                <ComboBoxItem Content="125%"/>
                                <ComboBoxItem Content="150%"/>
                                <ComboBoxItem Content="175%"/>
                                <ComboBoxItem Content="200%"/>
                                <ComboBoxItem Content="250%"/>
                                <ComboBoxItem Content="300%"/>
                            </ComboBox>
                            <RadioButton x:Name="ResizeByRateRadioButton" Content="リサイズ率を指定してリサイズ" 
                                         HorizontalAlignment="Left" Margin="10,31,0,0" VerticalAlignment="Top"
                                         Click="ResizeByRateRadioButton_Click"/>
                            <RadioButton x:Name="ResizeBySizeRadioButton" Content="ウィンドウサイズを指定してリサイズ"
                                         HorizontalAlignment="Left" Margin="10,103,0,0" VerticalAlignment="Top"
                                         Click="ResizeBySizeRadioButton_Click"/>
                            <Label Content="幅:" HorizontalAlignment="Left" Margin="10,128,0,0" VerticalAlignment="Top"/>
                            <TextBox x:Name="GameWindowWidthBox" HorizontalAlignment="Left" Margin="75,132,0,0" TextWrapping="NoWrap" 
                                     Text="" VerticalAlignment="Top" Width="120"/>
                            <Label Content="高さ:" HorizontalAlignment="Left" Margin="10,159,0,0" VerticalAlignment="Top"/>
                            <TextBox x:Name="GameWindowHeightBox" HorizontalAlignment="Left" Margin="75,163,0,0" TextWrapping="NoWrap" 
                                     Text="" VerticalAlignment="Top" Width="120"/>
                            <Button x:Name="ResizeButton"
                                    Content="リサイズ(_R)" Width="90" Height="24" HorizontalAlignment="Left" Margin="10,204,0,0" VerticalAlignment="Top" Click="ResizeButton_Click"/>
                            <Grid Margin="255,0,0,0" >
                                <Label Content="ゲーム実行時間" HorizontalAlignment="Left" Margin="10,51,0,0" VerticalAlignment="Top"/>
                                <TextBlock HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap"
                                       Text="データパネル" 
                                       VerticalAlignment="Top"/>
                                <TextBlock x:Name="GameRunningTimeBlock"
                                HorizontalAlignment="Left" Margin="113,43,0,0" TextWrapping="Wrap" Text="00min 00sec" VerticalAlignment="Top" FontSize="24" FontWeight="Bold"/>
                                <Label Content="物理メモリ使用量" HorizontalAlignment="Left" Margin="10,86,0,0" VerticalAlignment="Top"/>
                                <TextBlock x:Name="PagedMemorySizeBlock" HorizontalAlignment="Left" Margin="113,80,0,0" 
                                       TextWrapping="Wrap" Text="0MiB" VerticalAlignment="Top" FontSize="22" FontWeight="Bold"/>
                                <Label Content="仮想メモリ使用量" HorizontalAlignment="Left" Margin="10,120,0,0" VerticalAlignment="Top"/>
                                <TextBlock x:Name="VirtialMemorySizeBlock" HorizontalAlignment="Left" Margin="113,114,0,0" TextWrapping="Wrap"
                                           Text="0MiB" VerticalAlignment="Top" FontSize="22" FontWeight="Bold"/>

                            </Grid>
                        </Grid>
                    </ScrollViewer>

                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
