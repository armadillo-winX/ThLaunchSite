<Window x:Class="ThLaunchSite.CommandDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThLaunchSite"
        mc:Ignorable="d"
        Title="コマンド入力ウィンドウ" Height="175" Width="319" ResizeMode="NoResize" ShowInTaskbar="False" WindowStyle="ToolWindow" WindowStartupLocation="CenterOwner">
    <Grid>
        <TextBox x:Name="CommandBox"
                 TextWrapping="NoWrap" Text="" VerticalAlignment="Top" Margin="10,46,10,0" CharacterCasing="Lower"/>
        <Button x:Name="OKButton" IsDefault="True" Content="起動(_L)" HorizontalAlignment="Right" Margin="0,0,10,10"
                Width="90" Height="24" VerticalAlignment="Bottom" Click="OKButton_Click"/>
        <ComboBox x:Name="PatchOptionComboBox"
                  HorizontalAlignment="Left" Margin="102,12,0,0" VerticalAlignment="Top" Width="162">
            <ComboBoxItem Content="(なし)"/>
            <ComboBoxItem Content="VsyncPatch"/>
            <ComboBoxItem Content="thprac"/>
        </ComboBox>
        <Label Content="パッチの適用(_P):" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
