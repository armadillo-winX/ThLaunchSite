<Window x:Class="ThLaunchSite.CommandDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThLaunchSite"
        mc:Ignorable="d"
        Title="コマンド入力ウィンドウ" Height="145" Width="319" ResizeMode="NoResize" ShowInTaskbar="False" WindowStyle="ToolWindow" WindowStartupLocation="CenterOwner">
    <Grid>
        <TextBox x:Name="CommandBox"
                 TextWrapping="NoWrap" Text="" VerticalAlignment="Top" Margin="10,29,10,0" CharacterCasing="Lower"/>
        <Button x:Name="OKButton" IsDefault="True" Content="_OK" HorizontalAlignment="Right" Margin="0,0,10,10"
                Width="90" Height="24" VerticalAlignment="Bottom" Click="OKButton_Click"/>

    </Grid>
</Window>
